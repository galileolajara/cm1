                     return type
                  }
                  'c1.stdout{expr-base ": '*' operator cannot load this type\n"}
                  'c.exit(#failure)
               }
               case #plus {
                  type' = e-base.output(stars-c?, stars-bc?)
                  if (||, stars-c != #0, !type.is-arithmetic()) {
