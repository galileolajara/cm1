expr-index-address(expr'expr-index, out-stars-c'stars&)'type {
   type' = expr.obj.output(obj-stars-c?, obj-stars-bc?)
   if obj-stars-c == #0 {
      'c1.stdout{expr.base ": Subscripted expression is not an array or pointer\n"}
      'c.exit(#failure)
   }
   index-type' = expr.index.output(index-stars-c?, index-stars-bc?)
   if (||, index-stars-c != #0, !index-type.is-integer()) {
      'c1.stdout{expr.index ": Array index must have an integer type\n"}
      'c.exit(#failure)
   }
   array-dim-c' = expr-array-dim-c(expr.obj)
   element-size'u32 = 0
   if array-dim-c != 0 {
      array-dim-start' = expr-array-dim-start(expr.obj)
      outer-len' = .array-dim-v[array-dim-start]
      expr.array-dim-start = array-dim-start + 1
      expr.array-dim-c = array-dim-c - 1
      expr.array-size = expr-array-size(expr.obj) / outer-len
      element-size = expr.array-size
      if expr.array-dim-c != 0 {
         out-stars-c = obj-stars-c
      } else {
         out-stars-c = obj-stars-c - 'stars(1)
      }
   } else {
      out-stars-c = obj-stars-c - 'stars(1)
      element-size = type-storage-size(type, out-stars-c, expr.base.info)
   }
   bc-push-i32(element-size)
