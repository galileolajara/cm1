struct 'expr[info'line-info., type'expr-type] {
   // out-stars-c are number of asterisks in C
   // out-stars-bc are number of asterisks in bytecode
   output(expr-base'this, out-stars-c'stars&, out-stars-bc'stars&)'type {
      switch expr-base.type {
         case #call {
            expr'expr-call = expr-base
            func' = expr.func
            func-arg-start' = func.arg-start
            loop i' = 0; expr.arg-c; i++ {
               farg' = .func-decl-arg-v[func-arg-start + i]
               type' = expr.arg-v[i].output(stars-c?, stars-bc?)
               scalar-convert-assignment(type, stars-c, farg.type-final, farg.stars-final, expr.base.info)
            }
            if func.cm1 {
               bc-op(#call-cm1)
            } else {
               bc-op(#call-c)
            }
            bc-n16(func.func-idx)
            type' = func.type-final
            if (&&, type.is-aggregate(), func.stars-final == #0) {
               out-stars-c = #0
               out-stars-bc = #1
            } else {
               out-stars-c = func.stars-final
               out-stars-bc = func.stars-final
            }
            return func.type-final
         }
         case #i32 {
            expr'expr-i32 = expr-base
            bc-op(#push-i32)
            bc-n32(expr.i32)
            out-stars-c = #0
            out-stars-bc = #0
            return .type-v[5]
         }
         case #string {
            expr'expr-string = expr-base
            bc-op(#push-string)
            if .expr-discard-bytecode-depth == 0 {
               expr.bytecode-offset = .cm1-bytecode-wtr.p4
            }
            bc-n32(expr.str-offset)
            out-stars-c = #1
            out-stars-bc = #1
            if char-is-signed() { return .type-v[1] }
            return .type-v[2]
         }
         case #f32 {
            expr'expr-f32 = expr-base
            bc-push-f32(expr.value)
            out-stars-c = #0
            out-stars-bc = #0
            return .type-v[9]
         }
         case #f64 {
            expr'expr-f64 = expr-base
            bc-push-f64(expr.value)
            out-stars-c = #0
            out-stars-bc = #0
            return .type-v[10]
         }
         case #unary {
            expr'expr-unary = expr-base
            e-base' = expr.expr
            switch expr.op {
               case #amp {
                  switch e-base.type {
                     case #var {
                        var'expr-var = e-base
                        if var.global {
                           gvar' = .gvar-v[var.var-idx]
                           if gvar.array-dim-c != 0 {
                              'c1.stdout{expr-base ": Taking the address of an array is not supported\n"}
                              'c.exit(#failure)
                           }
