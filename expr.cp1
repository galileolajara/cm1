      case #index {
         index'expr-index = expr
         return index.array-dim-start
      }
   }
   return 0
}
expr-array-dim-c(expr'expr)'u32 {
   switch expr.type {
      case #var {
         var'expr-var = expr
         if var.global {
            return .gvar-v[var.var-idx].array-dim-c
         }
         return .lvar-v[var.var-idx].array-dim-c
