                           out-stars-c = stars
                           out-stars-bc = stars
                           return type
                        }
                     }
                     if stars == #0 {
                        if type.is-aggregate() {
                           if expr.op != #set {
                              'c1.stdout{expr-base ": Invalid assignment type\n"}
                              'c.exit(#failure)
                           }
                           bc-op(#lvar-push)
                           bc-n16(var-idx)
                           type2' = expr.src.output(stars2-c?, stars2-bc?)
                           if (||, type2 != type, stars2-c != #0) {
                              'c1.stdout{expr-base ": Type mismatch\n"}
                              'c.exit(#failure)
                           }
                           bc-push-usz(type.size)
                           bc-op(#copy-mem)
                           out-stars-c = #0
                           out-stars-bc = #1
                           return type
                        } elif type.is-arithmetic() {
                           if expr.op == #set {
                              type2' = expr.src.output(stars2-c?, stars2-bc?)
                              scalar-convert-assignment(type2, stars2-c, type, #0, expr-base.info)
                           } else {
                              bc-op(#lvar-push)
                              bc-n16(var-idx)
                              type2' = expr.src.output(stars2-c?, stars2-bc?)
                              if stars2-c != #0 {
                                 'c1.stdout{expr-base ": Arithmetic assignment requires an arithmetic value\n"}
                                 'c.exit(#failure)
                              }
                              bc-arithmetic-compound(expr.op, type, type2, expr-base.info)
                           }
                           bc-op(#lvar-set)
                           bc-n16(var-idx)
                           out-stars-c = #0
                           out-stars-bc = #0
                           return type
                        } else {
                           'c1.stdout{expr-base ": Not yet implemented #7218\n"}
                           'c.exit(#failure)
                        }
                     } else {
                        switch expr.op {
                           case #set {
                              type2' = expr.src.output(stars2-c?, stars2-bc?)
                              if (||, type2 != type, stars2-c != stars) {
                                 'c1.stdout{expr-base ": Type mismatch\n"}
                                 'c.exit(#failure)
                              }
                              bc-op(#lvar-set)
                              bc-n16(var-idx)
                              out-stars-c = stars
                              out-stars-bc = stars
                              return type
                           }
                           default {
                              'c1.stdout{expr-base ": Not yet implemented #0124\n"}
                              'c.exit(#failure)
                           }
                        }
                     }
                  }
               }
               case #field {
                  des'expr-field = des-base
                  obj-type' = des.obj.output(obj-stars-c?, obj-stars-bc?)
                  if !obj-type.is-aggregate() {
                     'c1.stdout{des.obj ": Field access on a variable that is not a struct or union\n"}
                     'c.exit(#failure)
                  }
                  if obj-stars-c == #0 {
                     if des.arrow {
                        'c1.stdout{des.obj ": Dot must be used instead of arrow\n"}
                        'c.exit(#failure)
                     }
                  } elif obj-stars-c == #1 {
                     if !des.arrow {
                        'c1.stdout{des.obj ": Arrow must be used instead of dot\n"}
                        'c.exit(#failure)
                     }
                  } else {
                     'c1.stdout{des.obj ": Not yet implemented #4398\n"}
                     'c.exit(#failure)
                  }
                  field-v' = obj-type.field-v
                  field-name' = des.field-name
                  loop i' = 0; obj-type.field-c; i++ {
                     field' = field-v[i]
                     if field.name == field-name {
                        if field.array-dim-c != 0 {
                           'c1.stdout{expr-base ": Arrays are not assignable\n"}
                           'c.exit(#failure)
                        }
                        field-type' = field.type-final
                        field-stars' = field.stars-final
                        bc-push-i32(field.offset)
                        if (&&, field-stars == #0, field-type.is-arithmetic()) {
                           if expr.op != #set {
                              // Keep the address and offset while loading the old value.
                              bc-op(#dup-pair)
                              bc-push-mem-arithmetic(field-type)
                           }
                           type' = expr.src.output(stars-c?, stars-bc?)
                           if stars-c != #0 {
                              'c1.stdout{expr-base ": Arithmetic assignment requires an arithmetic value\n"}
                              'c.exit(#failure)
                           }
                           if expr.op == #set {
                              scalar-convert-assignment(type, stars-c, field-type, #0, expr-base.info)
                           } else {
                              bc-arithmetic-compound(expr.op, field-type, type, expr-base.info)
                           }
                           bc-set-mem-arithmetic(field-type)
                           out-stars-c = #0
                           out-stars-bc = #0
                           return field-type
                        }
                        if (&&, field-stars == #0, field-type.is-aggregate()) {
                           if expr.op != #set {
                              'c1.stdout{expr-base ": Invalid assignment type\n"}
                              'c.exit(#failure)
                           }
                           bc-op(#addr-add)
                           type' = expr.src.output(stars-c?, stars-bc?)
                           if (||, type != field-type, stars-c != #0) {
                              'c1.stdout{expr-base ": Type mismatch\n"}
                              'c.exit(#failure)
                           }
                           bc-push-usz(field-type.size)
                           bc-op(#copy-mem)
                           out-stars-c = #0
                           out-stars-bc = #1
                           return field-type
                        }
                        'c1.stdout{expr-base ": Field assignment is not supported for this type\n"}
                        'c.exit(#failure)
                     }
                  }
                  'c1.stdout{des.obj ": Member field '" field-name "' not found.\n"}
                  'c.exit(#failure)
               }
               case #index {
                  des'expr-index = des-base
                  type' = expr-index-address(des, stars-c?)
                  if des.array-dim-c != 0 {
                     'c1.stdout{expr-base ": Arrays are not assignable\n"}
                     'c.exit(#failure)
                  }
                  if stars-c == #0 {
                     if type.is-arithmetic() {
                        bc-zero()
                        if expr.op != #set {
                           bc-op(#dup-pair)
                           bc-push-mem-arithmetic(type)
                        }
                        type2' = expr.src.output(stars2-c?, stars2-bc?)
                        if stars2-c != #0 {
                           'c1.stdout{expr-base ": Arithmetic assignment requires an arithmetic value\n"}
                           'c.exit(#failure)
                        }
                        if expr.op == #set {
                           scalar-convert-assignment(type2, stars2-c, type, #0, expr-base.info)
                        } else {
                           bc-arithmetic-compound(expr.op, type, type2, expr-base.info)
                        }
                        bc-set-mem-arithmetic(type)
                        out-stars-c = #0
                        out-stars-bc = #0
                        return type
                     } elif type.is-aggregate() {
                        if expr.op != #set {
                           'c1.stdout{expr-base ": Invalid assignment type\n"}
                           'c.exit(#failure)
                        }
                        type2' = expr.src.output(stars2-c?, stars2-bc?)
                        if (||, type2 != type, stars2-c != #0) {
                           'c1.stdout{expr-base ": Type mismatch\n"}
                           'c.exit(#failure)
                        }
                        bc-push-usz(type.size)
                        bc-op(#copy-mem)
                        out-stars-c = #0
                        out-stars-bc = #1
                        return type
                     }
                  } else {
                     if expr.op != #set {
                        'c1.stdout{expr-base ": Invalid assignment type\n"}
                        'c.exit(#failure)
                     }
                     bc-zero()
                     type2' = expr.src.output(stars2-c?, stars2-bc?)
                     if (||, type2 != type, stars2-c != stars-c) {
                        'c1.stdout{expr-base ": Type mismatch\n"}
                        'c.exit(#failure)
                     }
                     bc-op(#set-mem-ptr)
                     out-stars-c = stars-c
                     out-stars-bc = stars-c
                     return type
                  }
                  'c1.stdout{expr-base ": Array element type cannot be assigned\n"}
                  'c.exit(#failure)
               }
            }
            'c1.stdout{expr-base ": Assigning to an expression type #" des-base.type " is not yet implemented\n"}
            'c.exit(#failure)
         }
         case #conditional {
            expr'expr-conditional = expr-base

            // Determine both branch types without retaining their bytecode so
            // the selected branch can be converted to one common result type.
            saved-pos' = .cm1-bytecode-wtr.pos
            .expr-discard-bytecode-depth++
            then-type' = expr.then-expr.output(then-stars-c?, then-stars-bc?)
            .cm1-bytecode-wtr.pos = saved-pos
            false-type' = expr.false-expr.output(false-stars-c?, false-stars-bc?)
            .expr-discard-bytecode-depth--
            .cm1-bytecode-wtr.pos = saved-pos

            result-type'type = null
            result-stars-c'stars = #0
            result-stars-bc'stars = #0
            arithmetic-result'bool = false
            then-null' = expr-is-zero(expr.then-expr)
            false-null' = expr-is-zero(expr.false-expr)

            if (&&, then-stars-c == #0, false-stars-c == #0,
               then-type.is-arithmetic(), false-type.is-arithmetic()) {
               result-type = arithmetic-common-type(then-type, false-type)
               arithmetic-result = true
            } elif (&&, then-type == false-type, then-stars-c == false-stars-c,
               then-stars-bc == false-stars-bc) {
               result-type = then-type
               result-stars-c = then-stars-c
               result-stars-bc = then-stars-bc
            } elif (&&, then-stars-c != #0, false-stars-c == #0, false-null) {
               result-type = then-type
               result-stars-c = then-stars-c
               result-stars-bc = then-stars-bc
            } elif (&&, false-stars-c != #0, then-stars-c == #0, then-null) {
               result-type = false-type
               result-stars-c = false-stars-c
               result-stars-bc = false-stars-bc
            } elif (&&, then-stars-c != #0, then-stars-c == false-stars-c,
               (||, then-type.kind == #void, false-type.kind == #void)) {
               if then-type.kind == #void {
                  result-type = then-type
                  result-stars-bc = then-stars-bc
               } else {
                  result-type = false-type
                  result-stars-bc = false-stars-bc
               }
               result-stars-c = then-stars-c
            } else {
               'c1.stdout{expr-base ": Ternary branches have incompatible types\n"}
               'c.exit(#failure)
            }

            condition-type' = expr.condition.output(condition-stars-c?, condition-stars-bc?)
            if (&&, condition-stars-c == #0, !condition-type.is-arithmetic()) {
               'c1.stdout{expr.condition ": Ternary condition must have a scalar type\n"}
               'c.exit(#failure)
            }
            bc-scalar-to-bool(condition-type, condition-stars-c)
            false-jump-ptr' = bc-jump-begin(#jump-if-zero)

            actual-then-type' = expr.then-expr.output(actual-then-stars-c?, actual-then-stars-bc?)
            if arithmetic-result {
               bc-number-convert(actual-then-type, result-type)
            }
            end-jump-ptr' = bc-jump-begin(#jump)
            bc-jump-end(false-jump-ptr)

            actual-false-type' = expr.false-expr.output(actual-false-stars-c?, actual-false-stars-bc?)
            if arithmetic-result {
               bc-number-convert(actual-false-type, result-type)
            }
            bc-jump-end(end-jump-ptr)

            out-stars-c = result-stars-c
            out-stars-bc = result-stars-bc
            return result-type
         }
         case #logical {
            expr'expr-logical = expr-base
            type1' = expr.op1.output(stars1-c?, stars1-bc?)
            if (&&, stars1-c == #0, !type1.is-arithmetic()) {
               'c1.stdout{expr.op1 ": Logical operator requires scalar operands\n"}
               'c.exit(#failure)
            }
            bc-scalar-to-bool(type1, stars1-c)
            short-jump-ptr' = bc-jump-begin(#jump-if-zero)
            if expr.is-and {
               type2' = expr.op2.output(stars2-c?, stars2-bc?)
               if (&&, stars2-c == #0, !type2.is-arithmetic()) {
                  'c1.stdout{expr.op2 ": Logical operator requires scalar operands\n"}
                  'c.exit(#failure)
               }
               bc-scalar-to-bool(type2, stars2-c)
               bc-op(#logical-not)
               bc-op(#logical-not)
               end-jump-ptr' = bc-jump-begin(#jump)
               bc-jump-end(short-jump-ptr)
               bc-zero()
               bc-jump-end(end-jump-ptr)
            } else {
               bc-push-i32(1)
               end-jump-ptr' = bc-jump-begin(#jump)
               bc-jump-end(short-jump-ptr)
               type2' = expr.op2.output(stars2-c?, stars2-bc?)
               if (&&, stars2-c == #0, !type2.is-arithmetic()) {
                  'c1.stdout{expr.op2 ": Logical operator requires scalar operands\n"}
                  'c.exit(#failure)
               }
               bc-scalar-to-bool(type2, stars2-c)
               bc-op(#logical-not)
               bc-op(#logical-not)
               bc-jump-end(end-jump-ptr)
            }
            out-stars-c = #0
            out-stars-bc = #0
            return .type-v[5]
         }
         case #math {
            expr'expr-math = expr-base
            type1' = expr.op1.output(stars1-c?, stars1-bc?)
            type2' = expr.op2.output(stars2-c?, stars2-bc?)
            comparison' = (&&, expr.op >= #lt, expr.op <= #ne)
            if (&&, stars1-c == #0, stars2-c == #0) {
               if (&&, type1.is-arithmetic(), type2.is-arithmetic()) {
                  if (||, type1.is-floating(), type2.is-floating()) {
                     if (&&, expr.op > #div, !comparison) {
                        'c1.stdout{expr-base ": This operator requires integer operands\n"}
                        'c.exit(#failure)
                     }
                     result-type' = arithmetic-common-type(type1, type2)
                     bc-float-binary(expr.op, type1, type2, result-type)
                     out-stars-c = #0
                     out-stars-bc = #0
                     if comparison { return .type-v[5] }
                     return result-type
                  }
                  result-type' = integer-common-type(type1, type2)
                  if (||, expr.op == #shl, expr.op == #shr) {
                     result-type = type1.integer-promote()
                  }
                  bc-int-binary(expr.op, result-type)
                  out-stars-c = #0
                  out-stars-bc = #0
                  if comparison { return .type-v[5] }
                  return result-type
               }
               'c1.stdout{expr-base ": Arithmetic operands must have arithmetic types\n"}
               'c.exit(#failure)
            }
            if comparison {
               if (||, type1 != type2, stars1-c != stars2-c) {
                  'c1.stdout{expr-base ": Type mismatch for pointer comparison\n"}
                  'c.exit(#failure)
               }
               bc-int-binary(expr.op, target-size-type())
               out-stars-c = #0
               out-stars-bc = #0
               return .type-v[5]
            }
            // Pointer address calculations retain the existing bytecode path.
            if (&&, stars1-c != #0, stars2-c == #0, type2.is-integer()) {
               if expr.op == #add {
                  bc-op(#addr-add)
                  out-stars-c = stars1-c
                  out-stars-bc = stars1-bc
                  return type1
               } elif expr.op == #sub {
                  bc-op(#addr-sub)
                  out-stars-c = stars1-c
                  out-stars-bc = stars1-bc
                  return type1
               }
            }
            'c1.stdout{expr-base ": Unsupported pointer arithmetic\n"}
            'c.exit(#failure)
         }
         default {
            'c1.stdout{expr-base ": Method .output() not yet implemented in expression type #" expr-base.type " (" 'base(expr-base.type) ")\n"}
            'c.exit(#failure)
         }
      }
      'c1.stdout{expr-base ": Method .output() in expression type #" expr-base.type " (" 'base(expr-base.type) ") did not return a type\n"}
      'c.exit(#failure)
      return null
   }
}
}
