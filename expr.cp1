                           // entry, while aggregates already store a pointer
                           // to their byte-addressable frame storage.
                           bc-op(#lvar-push)
                           bc-n16(var.var-idx)
                           out-stars-c = lvar.stars-final + 'stars(1)
                           out-stars-bc = lvar.stars-final + 'stars(1)
                           return lvar.type-final
                        }
                     }
                     case #index {
                        index'expr-index = e-base
                        type' = expr-index-address(index, stars-c?)
                        out-stars-c = stars-c + 'stars(1)
                        out-stars-bc = stars-c + 'stars(1)
                        return type
                     }
                     default {
                        'c1.stdout{expr-base ": '&' operator is not supported here\n"}
                        'c.exit(#failure)
                     }
                  }
               }
               case #star {
                  type' = e-base.output(stars-c?, stars-bc?)
                  if stars-c == #0 {
                     'c1.stdout{expr-base ": '*' operator is not supported here\n"}
                     'c.exit(#failure)
                  }
                  stars-c--
                  if stars-c == #0 {
                     if type.is-aggregate() {
                        out-stars-c = #0
                        out-stars-bc = #1
                        return type
                     } elif type.is-arithmetic() {
                        bc-zero()
                        bc-push-mem-arithmetic(type)
