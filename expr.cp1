'c1 = 'libcp1
'c = 'libc
using 'cm1 {
#expr-call-stack-depth-limit = 32
#expr-call-arg-limit = 32
expr-call-stack-v'expr[#expr-call-stack-depth-limit][#expr-call-arg-limit]
expr-call-stack-c'u8[#expr-call-stack-depth-limit]
expr-call-stack-depth'u8
expr-call-begin() {
   depth' = .expr-call-stack-depth++
   .expr-call-stack-c[depth] = 0
}
expr-call-arg(expr'expr) {
   depth' = .expr-call-stack-depth - 1
   .expr-call-stack-v[depth][.expr-call-stack-c[depth]++] = expr
}
expr-i32(i32'i32, li'line-info)'expr {
   expr'expr-i32 = expr-alloc('expr-i32['usz], #i32, li)
   expr.i32 = i32
   return expr
}
expr-alloc(size'usz, type'expr-type, li'line-info)'ref {
   r'rdr. = ?
   r.ref = .cm1-data-mem
   r.pos += .cm1-data-pos
   .cm1-data-pos += (size + 7) & (0xffffffff ^ 7) // Align to 8 bytes
   expr'expr = r.ref
   expr.info.copy-from(li)
   expr.type = type
   return r.ref
}
enum 'expr-type[#none, #call, #i32, #assign, #math, #unary, #var, #field, #index, #inc-dec, #size-align, #cast, #logical, #f32, #f64, #conditional, #string]'u8 {
   cp1-name(e'this)'char @const[] @cp1-name
}
expr-call-fixed(func-name'id, arg-v'expr[], arg-c'u8, li'line-info)'expr {
   expr'expr-call = expr-alloc(('expr-call['usz] - 'usz['usz]) + ('usz['usz] * arg-c), #call, li)
   loop i' = 0; .func-c; i++ {
      if .func-name-v[i] == func-name {
         func' = .func-v[i]
         expr.func = func
         expr.arg-c = arg-c
         if func.arg-c != arg-c {
            'c1.stdout{li ": Function argument count must be " func.arg-c " in order to call the function at " func.info "\n"}
            'c.exit(#failure)
         }
         loop j' = 0; arg-c; j++ {
            expr.arg-v[j] = arg-v[j]
         }
         return expr
      }
   }
   'c1.stdout{li ": Function '" func-name "' not found\n"}
   'c.exit(#failure)
   return null
}
expr-call(func-name'id, li'line-info)'expr {
   depth' = .expr-call-stack-depth -= 1
   arg-c' = .expr-call-stack-c[depth]
   if func-name == .id-printf {
      return expr-printf(.expr-call-stack-v[depth], arg-c, li)
   }
   return expr-call-fixed(func-name, .expr-call-stack-v[depth], arg-c, li)
}
struct 'expr-call[base'expr., func'func, arg-c'u8, arg-v'expr[1]]
struct 'expr-i32[base'expr., i32'i32]
// String expressions live outside cm1-data-mem so their bytecode operands can
// be patched after the final string-pool position is known.
#string-limit = 1024 * 1024
struct 'expr-string[
   base'expr.,
   raw'char @const[],
   raw-len'u32,
   str-offset'u32,
   str-len'u32,
   bytecode-offset'u32[]
]
expr-str-v'expr-string.[#string-limit]
expr-str-c'u32
expr-discard-bytecode-depth'u32
expr-string-alloc(li'line-info)'expr-string {
   if .expr-str-c == #string-limit {
      'c1.stdout{li ": Too many string literal expressions\n"}
      'c.exit(#failure)
   }
   expr'expr-string = .expr-str-v[.expr-str-c++]
   expr.base.info.copy-from(li)
   expr.base.type = #string
   expr.bytecode-offset = null
   return expr
}
expr-string(raw'char @const[], raw-len'u32, li'line-info)'expr {
   expr'expr-string = expr-string-alloc(li)
   expr.raw = raw
   expr.raw-len = raw-len
   expr.str-offset = cm1-string-intern(raw, raw-len, li, expr.str-len)
   return expr
}
expr-string-decoded(decoded'char @const[], len'u32, li'line-info)'expr {
   expr'expr-string = expr-string-alloc(li)
   expr.raw = null
   expr.raw-len = 0
   expr.str-offset = cm1-string-intern-decoded(decoded, len, li, expr.str-len)
   return expr
}
expr-string-printf-text(decoded'char @const[], len'u32, li'line-info)'expr {
   expr'expr-string = expr-string-alloc(li)
   expr.raw = null
   expr.raw-len = 0
   expr.str-offset = cm1-string-intern-printf-text(decoded, len, li, expr.str-len)
   return expr
