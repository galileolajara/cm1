expr-printf-helper-id(conversion'char, li'line-info)'id {
   if (||, conversion == ''d, conversion == ''i) {
      return id-get("cm1_printf_d", 12)
   }
   if conversion == ''u { return id-get("cm1_printf_u", 12) }
   if conversion == ''o { return id-get("cm1_printf_o", 12) }
   if (||, conversion == ''x, conversion == ''X) {
      return id-get("cm1_printf_x", 12)
   }
   if (||, conversion == ''f, conversion == ''F,
      conversion == ''e, conversion == ''E,
      conversion == ''g, conversion == ''G,
      conversion == ''a, conversion == ''A) {
      return id-get("cm1_printf_f", 12)
   }
   if conversion == ''c { return id-get("cm1_printf_c", 12) }
   if conversion == ''s { return id-get("cm1_printf_s", 12) }
   if conversion == ''p { return id-get("cm1_printf_p", 12) }
   'c1.stdout{li ": Unsupported printf conversion '%" conversion "'\n"}
   'c.exit(#failure)
   return #nil
}
expr-printf(arg-v'expr[], arg-c'u8, li'line-info)'expr {
   if arg-c == 0 {
      'c1.stdout{li ": printf requires a format string\n"}
      'c.exit(#failure)
   }
   format-base' = arg-v[0]
   if format-base.type != #string {
      'c1.stdout{format-base ": printf format must be a string literal\n"}
      'c.exit(#failure)
   }
   format'expr-string = format-base
   format-str'char @const[] = &.cm1-bytecode.str[format.str-offset]
   format-len' = format.str-len
   loop i' = 0; format-len; i++ {
      if format-str[i] == ''\0 {
         'c1.stdout{format-base ": Embedded null bytes are not supported in printf formats\n"}
         'c.exit(#failure)
      }
   }

   current' = expr-call-fixed(id-get("cm1_printf_begin", 16), null, 0, li)
   helper-arg-v'expr[3]
   arg-i' = 1
   segment-begin' = 0
   pos' = 0
   loop pos < format-len {
      if format-str[pos] != ''% {
         pos++
         continue
      }
      pos++
      if (&&, pos < format-len, format-str[pos] == ''%) {
         pos++
         continue
      }

      loop pos < format-len {
         c'char = format-str[pos]
         if (||, c == ''-, c == ''+, c == '' , c == ''#, c == ''0, c == 39) {
            pos++
         } else { break }
      }
      if (&&, pos < format-len, format-str[pos] == ''*) {
         'c1.stdout{format-base ": printf '*' width arguments are not supported\n"}
         'c.exit(#failure)
      }
      loop (&&, pos < format-len, format-str[pos] >= ''0, format-str[pos] <= ''9) { pos++ }
      if (&&, pos < format-len, format-str[pos] == ''.) {
         pos++
         if (&&, pos < format-len, format-str[pos] == ''*) {
            'c1.stdout{format-base ": printf '*' precision arguments are not supported\n"}
            'c.exit(#failure)
         }
         loop (&&, pos < format-len, format-str[pos] >= ''0, format-str[pos] <= ''9) { pos++ }
      }
      if (&&, pos < format-len, (||, format-str[pos] == ''h, format-str[pos] == ''l)) {
         length-char'char = format-str[pos++]
         if (&&, pos < format-len, format-str[pos] == length-char) { pos++ }
      } elif (&&, pos < format-len,
         (||, format-str[pos] == ''j, format-str[pos] == ''z,
            format-str[pos] == ''t, format-str[pos] == ''L)) {
         pos++
      }
      if pos == format-len {
         'c1.stdout{format-base ": Incomplete printf conversion\n"}
         'c.exit(#failure)
      }
      conversion'char = format-str[pos++]
      helper-id' = expr-printf-helper-id(conversion, format-base.info)
      if arg-i == arg-c {
         'c1.stdout{format-base ": Not enough printf arguments for the format string\n"}
         'c.exit(#failure)
      }
      helper-arg-v[0] = current
      helper-arg-v[1] = expr-string-decoded(
         &format-str[segment-begin], pos - segment-begin, format-base.info)
      helper-arg-v[2] = arg-v[arg-i++]
      current = expr-call-fixed(helper-id, helper-arg-v, 3, li)
      segment-begin = pos
   }
   if arg-i != arg-c {
      'c1.stdout{format-base ": Too many printf arguments for the format string\n"}
      'c.exit(#failure)
   }
   helper-arg-v[0] = current
   helper-arg-v[1] = expr-string-printf-text(
      &format-str[segment-begin], format-len - segment-begin, format-base.info)
   return expr-call-fixed(id-get("cm1_printf_end", 14), helper-arg-v, 2, li)
}
struct 'expr-f32[base'expr., value'f32]
