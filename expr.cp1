                           out-stars-bc = gvar.stars-final + 'stars(1)
                           return gvar.type-final
                        } else {
                           lvar' = .lvar-v[var.var-idx]
                           if lvar.array-dim-c != 0 {
                              'c1.stdout{expr-base ": Taking the address of an array is not supported\n"}
                              'c.exit(#failure)
