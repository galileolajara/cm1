struct 'expr-var[base'expr., global'bool, var-idx'u32]
expr-var(name'id, li'line-info)'expr {
   expr'expr-var = expr-alloc('expr-var['usz], #var, li)
   i' = .lvar-name-c
   loop i > 0 {
      i--
      if .lvar-name-id-v[i] == name {
         expr.var-idx = .lvar-name-idx-v[i]
         return expr
      }
   }
   loop j' = 0; .gvar-c; j++ {
      if .gvar-name-v[j] == name {
         expr.global = true
         expr.var-idx = j
         return expr
      }
   }
   loop j' = .enum-member-c; j > 0; {
