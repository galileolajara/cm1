enum 'unary-op[#amp, #star, #plus, #minus, #tilde, #bang]'u8
struct 'expr-unary[base'expr., expr'expr, op'unary-op]
expr-unary(e'expr, op'unary-op)'expr {
   expr'expr-unary = expr-alloc('expr-unary['usz], #unary, e.info)
   expr.expr = e
   expr.op = op
   if (&&, e != null, op == #amp, e.type == #var) {
      var'expr-var = e
      if !var.global { .lvar-v[var.var-idx].address-taken = true }
   }
