   cp1-name(e'this)'char @const[] @cp1-name
}
bc-op(op'op) {
   // 'c1.stdout{op "\n"}
   .cm1-bytecode-wtr.op[0] = op
   .cm1-bytecode-wtr.pos++
}
bc-n8(val'u8) {
   .cm1-bytecode-wtr.p1[0] = val
   .cm1-bytecode-wtr.pos += 1
}
bc-n16(val'u16) {
   .cm1-bytecode-wtr.p2[0] = val
   .cm1-bytecode-wtr.pos += 2
}
bc-n32(val'u32) {
   .cm1-bytecode-wtr.p4[0] = val
   .cm1-bytecode-wtr.pos += 4
}
bc-n64(val'u64) {
   .cm1-bytecode-wtr.p8[0] = val
   .cm1-bytecode-wtr.pos += 8
}
bc-f32(val'f32) {
   .cm1-bytecode-wtr.f4[0] = val
   .cm1-bytecode-wtr.pos += 4
}
bc-f64(val'f64) {
   .cm1-bytecode-wtr.f8[0] = val
   .cm1-bytecode-wtr.pos += 8
}
bc-u(val'u32) {
   putu(.cm1-bytecode-wtr.p1, val)
}
bc-zero() {
   bc-op(#push-zero)
}
meta #meta-codes {
   using 'cm1 {
#  if .is-64bit {
      bc-push-usz(val'usz) {
         bc-push-u64('u64(val))
      }
      bc-push-isz(val'isz) {
         bc-push-i64('i64(val))
      }
#  } else {
      bc-push-usz(val'usz) {
         bc-push-u32('u32(val))
      }
      bc-push-isz(val'isz) {
         bc-push-i32('i32(val))
      }
#  }
   }
}
#meta-codes{}
bc-push-u32(val'i32) {
   if val == 0 {
      bc-zero()
   } elif val < 256 {
      bc-op(#push-u8)
      bc-n8(val)
   } elif val < 65536 {
      bc-op(#push-u16)
      bc-n32(val)
   } else {
      bc-op(#push-u32)
      bc-n32(val)
   }
}
bc-push-u64(val'u64) {
   if val == 0 {
      bc-zero()
   } elif val < 256 {
      bc-op(#push-u8)
      bc-n8(val)
   } elif val < 65536 {
      bc-op(#push-u16)
      bc-n32(val)
   } elif val < 4294967296u64 {
      bc-op(#push-u32)
      bc-n32(val)
   } else {
      bc-op(#push-u64)
      bc-n64(val)
   }
}
bc-push-i32(val'i32) {
   if val == 0 {
      bc-op(#push-zero)
   } else {
      bc-op(#push-i32)
      bc-n32(val)
   }
}
bc-push-f32(val'f32) {
   bc-op(#push-f32)
   bc-f32(val)
}
bc-push-f64(val'f64) {
   bc-op(#push-f64)
   bc-f64(val)
}
bc-i(val'u32) {
   puti(.cm1-bytecode-wtr.p1, val)
}
