gvar-decl(type'type, stars'stars, extern'bool, name'id, array-dims'u32[], array-dim-c'u32, li'line-info) {
   "#ifdef __EMSCRIPTEN__"
   'c1.stdout{li ": Global variables are not supported yet in web builds but works on builds for Linux, FreeBSD, Windows, Android, macOS and iOS.\n"}
   'c.exit(#failure)
   "#endif"
   .gvar-name-v[.gvar-c] = name
   gvar' = .gvar-v[.gvar-c++]
   gvar.info.copy-from(li)
   gvar.type-src = type
   gvar.stars-src = stars
   gvar.type-final = type.final-type(stars, gvar.stars-final)
   gvar.array-dim-c = array-dim-c
   if array-dim-c != 0 {
      array-decl(gvar.type-final, gvar.stars-final, array-dims, array-dim-c, li, gvar.array-dim-start, gvar.array-size)
   }
   gvar.extern = extern
   d' = .decl-c++
