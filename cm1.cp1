stmt-alloc(size'usz, type'stmt-type, li'line-info)'ref {
   r'rdr. = ?
   r.ref = .cm1-data-mem
   r.pos += .cm1-data-pos
   .cm1-data-pos += (size + 7) & (0xffffffff ^ 7) // Align to 8 bytes
   stmt'stmt = r.ref
   stmt.info.copy-from(li)
