}
cm1-string-intern-candidate(start'u32, pos'u32, li'line-info, out-len'u32&)'u32 {
   len' = pos - start
   crc' = crc32c(0, &.cm1-bytecode.str[start], len)
   loop i' = 0; .cm1-string-count; i++ {
      if (&&, .cm1-string-crc32c-v[i] == crc, .cm1-string-len-v[i] == len,
         'c.memcmp(&.cm1-bytecode.str[.cm1-string-offset-v[i]], &.cm1-bytecode.str[start], len) == 0) {
         out-len = len
