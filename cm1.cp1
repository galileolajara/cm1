id-printf'id
main(arg-c'cint, arg-v'char @const[][])'cint {
   if false {
      export()
   }

   if arg-c != 5 {
      'c1.stdout{"Usage: " arg-v[0] " <input-file.cm1.c> <input-file.cm1.cfg> <output-file.c> <output-file.cm1>\n"}
      'c.exit(#failure)
   }
   in-path' = arg-v[1]
   cfg-path' = arg-v[2]
   out-path' = arg-v[3]
   cm1-path' = arg-v[4]

   fd' = 'x.open(cfg-path, #rdonly)
   if fd == #nil {
      'c1.stdout{"Cannot read file: " cfg-path "\n"}
      'c.exit(#failure)
   }
   cfg-len' = fd.seek(0, #end)
   fd.seek(0, #set)
   cfg-data'char[] = cfg-mem(cfg-len)
   fd.read(cfg-data, cfg-len)
   fd.close()
   cfg-data[cfg-len] = ''\n
   cfg-data[cfg-len + 1] = ''\0
   cfg-pos' = ?
   if (&&, cfg-data[0] == ''C, cfg-data[1] == ''M, cfg-data[2] == ''1, cfg-data[3] == ''\n) {
      .cfg-has-cm1 = true
      cfg-pos = 4
   } elif (&&, cfg-data[0] == ''C, cfg-data[1] == ''\n) {
      cfg-pos = 2
   } else {
      'c1.stdout{"The file " cfg-path " must begin with either 'CM1' or 'C' followed by a new line\n"}
      'c.exit(#failure)
   }
   loop {
      line-begin' = cfg-pos
      loop {
         if cfg-data[cfg-pos] == ''\0 {
            "goto cfg_func_list_end;"
         }
         if cfg-data[cfg-pos] == ''\n {
            break
         }
         cfg-pos++
      }
      line-len' = cfg-pos - line-begin
      if line-len == 0 { break }
      id-get(&cfg-data[line-begin], line-len) // Create an id for the function name
      cfg-pos++ // Skip the new line
   }
   "cfg_func_list_end:;"
   .cfg-func-list = .id-c

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("void", 4)
      type.kind = #void
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("int8_t", 6)
      type.kind = #i8
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("uint8_t", 7)
      type.kind = #u8

      tn' = .typename-c++
      .typename-id-v[tn] = id-get("bool", 4)
      .typename-type-v[tn] = type
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("int16_t", 7)
      type.kind = #i16
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("uint16_t", 8)
      type.kind = #u16
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("int32_t", 7)
      type.kind = #i32
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("uint32_t", 8)
      type.kind = #u32
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("int64_t", 7)
      type.kind = #i64
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("uint64_t", 8)
      type.kind = #u64
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("float", 5)
      type.kind = #f32
   }

   if true {
      type' = .type-v[.type-c++]
      type.name = id-get("double", 6)
      type.kind = #f64
   }

   .id-printf = id-get("printf", 6)

   .cm1-bytecode-wtr.ref = .cm1-bytecode.buf
   parse(in-path)

   if true { // Write C file
      'c1.sprintf(.c-code-buf, f?)
      f.len += 12 // Leave space for the crc32c comment
      f.add{cm1-h(), cm1-h-len()}
      decl-c' = .decl-c
      loop i' = 0; i < decl-c; i++ {
         switch .decl-type-v[i] {
            case #aggregate-forward {
               type'type = .decl-ptr-v[i]
               output-type-name(f, type)
               f.add{";\n"}
            }
            case #aggregate {
               type'type = .decl-ptr-v[i]
               output-type-name(f, type)
               f.add{" {\n"}
               output-fields(f, type)
               f.add{"};\n"}
            }
            case #enum {
               type'type = .decl-ptr-v[i]
               output-type-name(f, type)
               f.add{" {\n"}
               output-enum-members(f, type)
               f.add{"};\n"}
            }
            case #gvar {
               gvar'gvar = .decl-ptr-v[i]
               type' = gvar.type-src
               if (||, type.is-aggregate(), type.kind == #enum) {
                     if (&&, gvar.stars-final == #0, type.field-v == null) {
                        'c1.stdout{gvar.info ": Struct, union, or enum '" type.name "' was used but it was never defined\n"}
                        'c.exit(#failure)
                     }
                     output-type-name(f, type)
                     f.add{gvar.stars-src ''  gvar.name()}
               } elif type.kind == #typedef {
                     type2' = gvar.type-final
                     if (&&, type2.is-aggregate(), gvar.stars-final == #0, type2.field-v == null) {
                        'c1.stdout{gvar.info ": Struct or union '" gvar.type-src.name "' was used but it was never defined\n"}
                        'c.exit(#failure)
                     }
                     f.add{type.name gvar.stars-src ''  gvar.name()}
               } else {
                     f.add{type.name gvar.stars-src ''  gvar.name()}
               }
               output-array-dims(f, gvar.array-dim-start, gvar.array-dim-c)
               f.add{";\n"}
            }
            case #func-forward {
               func'func = .decl-ptr-v[i]
               type' = func.type-src
               stars' = func.stars-src
               // A runtime header may expose the function through a macro (for
               // example, fortified versions of memcpy). In that case the
               // header already supplies its declaration, and spelling the
               // declaration again would expand the macro in invalid syntax.
               f.add{"#ifndef " func.name() "\n"}
               output-type-name(f, type)
               f.add{stars ''  func.name() ''(}
               arg-start' = func.arg-start
               loop j' = 0; func.arg-c; j++ {
                  if j != 0 {
                     f.add{", "}
                  }
                  farg' = .func-decl-arg-v[arg-start + j]
                  type2' = farg.type-src
                  stars2' = farg.stars-src
                  output-type-name(f, type2)
                  f.add{''  stars2 farg.name}
               }
               f.add{");\n#endif\n"}
            }
            case #typedef-aggregate {
               type'type = .decl-ptr-v[i]
               f.add{"typedef "}
               if type.kind == #union {
                  f.add{"union"}
               } else {
                  f.add{"struct"}
               }
               f.add{" {\n"}
               output-fields(f, type)
               f.add{"}"}
               first' = true
               loop (i + 1) < decl-c {
                  if .decl-type-v[i + 1] != #typedef-name { break }
                  i++
                  type2'type = .decl-ptr-v[i]
                  if first {
                     first = false
                     f.add{''  type2.stars() type2.name}
                  } else {
                     f.add{", " type2.stars() type2.name}
                  }
               }
               f.add{";\n"}
            }
            case #typedef-enum {
               type'type = .decl-ptr-v[i]
               f.add{"typedef enum {\n"}
               output-enum-members(f, type)
               f.add{"}"}
               first' = true
               loop (i + 1) < decl-c {
                  if .decl-type-v[i + 1] != #typedef-name { break }
                  i++
                  type2'type = .decl-ptr-v[i]
                  if first {
                     first = false
                     f.add{''  type2.stars() type2.name}
                  } else {
                     f.add{", " type2.stars() type2.name}
                  }
               }
               f.add{";\n"}
            }
            case #typedef {
               type'type = .decl-ptr-v[i]
               stars-minus'stars = #0
               if (||, type.is-aggregate(), type.kind == #enum) {
                  f.add{"typedef "}
                  output-type-name(f, type)
               } else {
                  f.add{"typedef " type.name}
                  stars-minus = type.stars()
               }
               first' = true
               loop (i + 1) < decl-c {
                  if .decl-type-v[i + 1] != #typedef-name { break }
                  i++
                  type2'type = .decl-ptr-v[i]
                  if first {
                     first = false
                     f.add{''  type2.stars() - stars-minus type2.name}
                  } else {
                     f.add{", " type2.stars() - stars-minus type2.name}
                  }
               }
               f.add{";\n"}
            }
            case #func {
               func'func = .decl-ptr-v[i]
               if func.cm1 {
                  type' = func.type-src
                  stars' = func.stars-src
                  output-type-name(f, type)
                  f.add{stars ''  func.name() ''(}
                  arg-start' = func.arg-start
                  loop j' = 0; func.arg-c; j++ {
                     if j != 0 {
                        f.add{", "}
                     }
                     farg' = .func-decl-arg-v[arg-start + j]
                     type2' = farg.type-src
                     stars2' = farg.stars-src
                     output-type-name(f, type2)
                     f.add{''  stars2 farg.name}
                  }
                  f.add{") {\n"}
                  loop j' = 0; func.arg-c; j++ {
                     farg' = .func-decl-arg-v[arg-start + j]
                     type2' = farg.type-final
                     stars2' = farg.stars-final
                     if stars2 == #0 {
                        if type2.is-aggregate() {
                           f.add{"   cm1_push_ptr(&" farg.name ");\n"}
                        } elif type2.is-integer() {
                           if type2.is-signed-integer() {
                              f.add{"   cm1_push_i(" farg.name ");\n"}
                           } else {
                              f.add{"   cm1_push_u(" farg.name ");\n"}
                           }
                        } elif type2.kind == #f32 {
                           f.add{"   cm1_push_f32(" farg.name ");\n"}
                        } elif type2.kind == #f64 {
                           f.add{"   cm1_push_f64(" farg.name ");\n"}
                        }
                     } else {
                        f.add{"   cm1_push_ptr(" farg.name ");\n"}
                     }
                  }
                  f.add{"   cm1_run(" func.func-idx ");\n"}
                  if func.stars-final == #0 {
                     type2' = func.type-final
                     if type2.is-aggregate() {
                        f.add{"   return *("}
                        output-type-name(f, type2)
                        f.add{"*)cm1_pop_ptr();\n"}
                     } elif type2.is-integer() {
                        if type2.is-signed-integer() {
                           f.add{"   return cm1_pop_i64();\n"}
                        } else {
                           f.add{"   return cm1_pop_u64();\n"}
                        }
                     } elif type2.kind == #f32 {
                        f.add{"   return cm1_pop_f32();\n"}
                     } elif type2.kind == #f64 {
                        f.add{"   return cm1_pop_f64();\n"}
                     } elif type2.kind == #void {
                        f.add{"   (void)cm1_pop_ptr();\n"}
                     }
                  } else {
                     f.add{"   return cm1_pop_ptr();\n"}
                  }
                  f.add{"}\n"}
                  continue
               }
               if func.code == null { continue }
               code'char @const[] = func.code
               type' = func.type-src
               stars' = func.stars-src
               output-type-name(f, type)
               f.add{stars ''  func.name() ''(}
               arg-start' = func.arg-start
               loop j' = 0; func.arg-c; j++ {
                  if j != 0 {
                     f.add{", "}
                  }
                  farg' = .func-decl-arg-v[arg-start + j]
                  type2' = farg.type-src
                  stars2' = farg.stars-src
                  output-type-name(f, type2)
                  f.add{''  stars2 farg.name}
               }
               f.add{") " code, func.code-len "\n"}
            }
         }
      }
      f.add{"void* cm1_gvar(uint16_t var_idx) {\n"}
      f.add{"   switch (var_idx) {\n"}
      loop i' = 0; .gvar-c; i++ {
         gvar' = .gvar-v[i]
         f.add{"      case " i ": {\n"}
         if gvar.stars-final == #0 {
            f.add{"         return &" gvar.name() ";\n"}
         } else {
            f.add{"         return " gvar.name() ";\n"}
         }
         f.add{"      }\n"}
      }
      f.add{"   }\n"}
      f.add{"   return NULL;\n"}
      f.add{"}\n"}
      f.add{"void cm1_run_c(uint16_t func_idx) {\n"}
      f.add{"   switch (func_idx) {\n"}
      loop i' = 0; .func-c; i++ {
         func' = .func-v[i]
         if func.cm1 { continue }
         f.add{"      case " func.func-idx ": {\n"}
         arg-start' = func.arg-start
         farg-c' = func.arg-c
         loop j' = farg-c; farg-c; {
            j--
            farg' = .func-decl-arg-v[arg-start + j]
            type' = farg.type-final
            stars' = farg.stars-final
            if stars == #0 {
               if type.is-aggregate() {
                  f.add{"         "}
                  output-type-name(f, farg.type-src)
                  f.add{" arg" j " = *("}
                  output-type-name(f, farg.type-src)
                  f.add{"*)cm1_pop_ptr();\n"}
               } else {
                  switch type.kind {
                     case #i8 {
                        f.add{"         int8_t arg" j " = cm1_pop_i64();\n"}
                     }
                     case #i16 {
                        f.add{"         int16_t arg" j " = cm1_pop_i64();\n"}
                     }
                     case #i32 {
                        f.add{"         int32_t arg" j " = cm1_pop_i64();\n"}
                     }
                     case #i64 {
                        f.add{"         int64_t arg" j " = cm1_pop_i64();\n"}
                     }
                     case #u8 {
                        f.add{"         uint8_t arg" j " = cm1_pop_u64();\n"}
                     }
                     case #u16 {
                        f.add{"         uint16_t arg" j " = cm1_pop_u64();\n"}
                     }
                     case #u32 {
                        f.add{"         uint32_t arg" j " = cm1_pop_u64();\n"}
                     }
                     case #u64 {
                        f.add{"         uint64_t arg" j " = cm1_pop_u64();\n"}
                     }
                     case #f32 {
                        f.add{"         float arg" j " = cm1_pop_f32();\n"}
                     }
                     case #f64 {
                        f.add{"         double arg" j " = cm1_pop_f64();\n"}
                     }
                  }
               }
            } else {
               f.add{"         void* arg" j " = cm1_pop_ptr();\n"}
            }
         }
         type' = func.type-final
         kind' = type.kind
         stars' = func.stars-final
         if stars == #0 {
            if kind == #void {
               f.add{"         "}
            } elif type.is-aggregate() {
               f.add{"         "}
               output-type-name(f, func.type-src)
               f.add{" ret = "}
            } elif type.is-arithmetic() {
               f.add{"         "}
               output-type-name(f, func.type-src)
               f.add{" ret = "}
            } else {
               f.add{"         int32_t ret = "}
            }
         } else {
            f.add{"         void* ret = "}
         }
         f.add{func.name() ''(}
         loop j' = 0; farg-c; j++ {
            if j != 0 {
               f.add{", "}
            }
            f.add{"arg" j}
         }
         f.add{");\n"}
         if stars == #0 {
            if type.is-aggregate() {
               f.add{"         cm1_push_ptr(&ret);\n"}
            } elif kind == #void {
               f.add{"         cm1_push_ptr(0);\n"}
            } elif type.is-signed-integer() {
               f.add{"         cm1_push_i(ret);\n"}
            } elif type.is-integer() {
               f.add{"         cm1_push_u(ret);\n"}
            } elif kind == #f32 {
               f.add{"         cm1_push_f32(ret);\n"}
            } elif kind == #f64 {
               f.add{"         cm1_push_f64(ret);\n"}
            }
         } else {
            f.add{"         cm1_push_ptr(ret);\n"}
         }
         f.add{"         break;\n"}
         f.add{"      }\n"}
      }
      f.add{"   }\n"}
      f.add{"}\n"}
      f.add{cm1-c(), cm1-c-len()}

      f-len' = f.len
      crc32c' = crc32c(0, &.c-code-buf[12], f-len - 12)
      .c-code-buf[0] = ''/
      .c-code-buf[1] = ''/
      .c-code-buf[2] = '' 
      crc32c-v'u8[] = &crc32c
      loop i' = 3, j' = 3; 4; {
         n' = crc32c-v[i--]
         a' = n >> 4
         if a < 10 {
            .c-code-buf[j++] = ''0 + a
         } else {
            .c-code-buf[j++] = ''a + (a - 10)
         }
         a = n & 15
         if a < 10 {
            .c-code-buf[j++] = ''0 + a
         } else {
            .c-code-buf[j++] = ''a + (a - 10)
         }
      }
      .c-code-buf[3 + 8] = ''\n
      write' = true
      fd = 'x.open(out-path, #rdonly)
      if fd != #nil {
         header'char[12]
         fd.read(header, 12)
         if 'c.memcmp(header, .c-code-buf, 12) == 0 {
            write = false
            "#ifndef __EMSCRIPTEN__"
            'c1.stdout{out-path " did not change\n"}
            "#endif"
         }
         fd.close()
      }
      if write {
         fd = 'x.open(out-path, #create | #truncate | #wronly, 0o644)
         fd.write(.c-code-buf, f-len)
         fd.close()
      }
   }

   if true { // Write the bytecodes to cm1-path
      r1'rdr. = ?
      r1.ref = .cm1-bytecode.buf
      offset-start' = .func-bc-idx * 4
      r2'rdr. = ?
      r2.ref = .cm1-bytecode.buf
      r2.pos -= offset-start + 4 // +4 for the crc32c
      offset-v'u32[] = r2.ref
      loop i' = 0, j' = 1; .func-c; i++ {
         func' = .func-v[i]
         if !func.cm1 { continue }
         if func.code == null {
            'c1.stdout{func.info ": The function '" func.name() "' has no code.\n"}
            'c.exit(#failure)
         }
         r2.ref = func.code
         offset-v[j++] = (r2.pos - r1.pos) + offset-start
      }
      r2.ref = .cm1-bytecode-wtr.ref
      bc-len' = r2.pos - r1.pos
      string-start' = offset-start + bc-len
      loop i' = 0; .expr-str-c; i++ {
         expr'expr-string = .expr-str-v[i]
         if expr.bytecode-offset != null {
            expr.bytecode-offset[0] = string-start + expr.str-offset
         }
      }
      crc32c-new' = crc32c(0, &offset-v[1], offset-start + bc-len)
      crc32c-new = crc32c(crc32c-new, .cm1-bytecode.str, .cm1-string-pos)
      offset-v[0] = crc32c-new
      write' = true
      fd = 'x.open(cm1-path, #rdonly)
      if fd != #nil {
         crc32c-old'u32 = ?
         if (&&, fd.read(&crc32c-old, 'u32['usz]) == 4, crc32c-old == crc32c-new) {
            write = false
            "#ifndef __EMSCRIPTEN__"
            'c1.stdout{cm1-path " did not change\n"}
            "#endif"
         }
         fd.close()
      }
      
      if write {
         fd = 'x.open(cm1-path, #create | #truncate | #wronly, 0o644)
         if fd == #nil {
            'c1.stdout{"Cannot write file: " cm1-path "\n"}
            'c.exit(#failure)
         }
         fd.write(offset-v, offset-start + 4 + bc-len)
         fd.write(.cm1-bytecode.str, .cm1-string-pos)
         fd.close()
      }
   }
   return 0
}
}
using 'libcp1 {
   using 'fmt {
      f-reserve<id'cm1'id>(fmt'this, f'f-cstr) {
         if id == #nil {
            nil' = "<nil>"
            fmt.f-reserve-arr<nil>(5, f)
         } else {
            fmt.f-reserve-arr<id[]ptr>(id[]len, f)
         }
      }
      f-reserve<id'cm1'stars>(fmt'this, f'f-cstr) {
         stars' = "************************************************************************"
         fmt.f-reserve-arr<stars>('base(id), f)
      }
      f-reserve<op'cm1'op>(fmt'this, f'f-cstr) {
         fmt.f-reserve-arr<op.cp1-name()>(f)
      }
      f-reserve<kind'cm1'type-kind>(fmt'this, f'f-cstr) {
         fmt.f-reserve-arr<kind.cp1-name()>(f)
      }
      f-reserve<kind'cm1'stmt-type>(fmt'this, f'f-cstr) {
         fmt.f-reserve-arr<kind.cp1-name()>(f)
      }
      f-reserve<type'cm1'expr-type>(fmt'this, f'f-cstr) {
         fmt.f-reserve-arr<type.cp1-name()>(f)
      }
      f-reserve<expr'cm1'expr>(fmt'this, f'f-cm1-line-info) {
         fmt.f-reserve<expr.info>(f)
      }
      f-reserve<li'cm1'line-info>(fmt'this, f'f-cm1-line-info) {
         fmt.f-reserve-arr<li.path>(f.path)
         fmt.cap++ // For the colon
         fmt.f-reserve<li.row>(f.row)
         fmt.cap++ // For the colon
         fmt.f-reserve<li.col>(f.col)
      }
      struct 'f-cm1-line-info[path'f-cstr., row'f-u32., col'f-u32.] {
         f(f'this, fmt'fmt) {
            f.path.f(fmt)
            fmt.ptr[fmt.len++] = '':
            f.row.f(fmt)
            fmt.ptr[fmt.len++] = '':
            f.col.f(fmt)
         }
      }
   }
}
