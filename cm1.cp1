include "cm1_preprocess.c" {
   preprocess(in-path'char @const[], include-c'usz, include-v'char @const[][], define-c'usz, define-name-v'char @const[][], define-value-v'char @const[][])'usz @no-decl(preprocess)
   preprocess-error-message()'char @const[] @no-decl(preprocess_error_message)
}
parse(in-path'char @const[]) {
   include-v'char[1][]
   include-v[0] = "include"
   define-name-v'char[3][]
   define-name-v[0] = "__CM1__"
   define-name-v[1] = "__STDC__"
   define-name-v[2] = "__STDC_VERSION__"
   define-value-v'char[3][]
   define-value-v[0] = ""
   define-value-v[1] = ""
   define-value-v[2] = "199901"
   in-size' = preprocess(in-path, 1, include-v, 3, define-name-v, define-value-v)
   if in-size == 0 {
      'c1.stdout{preprocess-error-message()}
      'c.exit(#failure)
   }
   in-data'char[] = .output-mem

   r-end'rdr. = ?
   r-end.ref = in-data
   r-end.pos += in-size

   .input-path = in-path
   psr' = 'parser.alloc()
   'lexer.init(lex?, in-data)
   next-row' = 1
   next-col' = 1
   .row = 1
   .col = 1
   tok'token-data.
   loop {
      tok.i32.row = next-row
      tok.i32.col = next-col
      t' = lex.scan()
      // lex-start'char[] = lex.start
      // 'c1.stdout{t.cp1-name() " " lex-start, 10 "\n"}
      if true {
         // when reporting the row and column of tokens, skip the spaces
         pos' = lex.start
         loop pos < r-end.p1 {
            if pos[0] == ''  {
               tok.i32.col++
            } elif pos[0] == ''\n {
               tok.i32.row++
               tok.i32.col = 1
            } else {
               break
            }
            pos++
         }
      }
      .last-row = .row
      .last-col = .col
      .row = tok.i32.row
      .col = tok.i32.col
      if (&&, t >= #int64, t < #void) {
         tok.ptr.ptr = builtin-type-token(t)
         tok.ptr.ptr2 = null // Not an extern
         t = #type
      } elif t == #void {
         // Keep void as its own parser token so "(void)" can be
         // distinguished from a named parameter whose type begins with void.
         tok.ptr.ptr = builtin-type-token(t)
         tok.ptr.ptr2 = null // Not an extern
      }
      switch t {
         case #spaces, #const, #static {
            // Do nothing
         }
         case #line-info {
            r1'rdr. = ?
            r1.ref = lex.start
            r1.pos += 2
            num' = 0
            c' = r1.p1[0]
            loop {
               num = (num * 10) + (c - ''0)
               r1.pos++
               c = r1.p1[0]
               if (||, c < ''0, c > ''9) { break }
            }
            if r1.p1[0] != ''  {
               "line_number_error:;"
               'c1.stdout{"Error in reading the syntax of line info\n"}
               'c.exit(#failure)
            }
            r1.pos++
            if r1.p1[0] != ''" {
               "goto line_number_error;"
            }
            r1.pos++
            r2'rdr. = ?
            r2.ref = r1.ref
            path'char @const[] = r2.ref
            loop {
               if r2.p1[0] == ''" { break }
               if r2.p1[0] == ''\0 {
                  "goto line_number_error;"
               }
               r2.pos++
            }
            r2.p1[0] = ''\0
            // path-len'u32 = r2.pos - r1.pos
            // 'c1.stdout{"line-num: " num " " path, path-len "\n"}
            .input-path = path
            tok.id.path = path
            next-row = num - 1
            next-col = 1
            // A preprocessor line marker updates source locations, but it is
            // not part of the C grammar. Forwarding it to the parser can make
            // it become the sole statement controlled by an if or loop.
         }
         case #func-c {
            tok.id.id = .func-name
            .last-token = t
            psr.parse(t, tok)
         }
         case #func-bc {
            tok.id.id = .func-name
            .last-token = t
            psr.parse(t, tok)
         }
         case #func {
            r1'rdr. = ?
            r1.ref = lex.start
            r2'rdr. = ?
            r2.ref = lex.cursor
            tok.id.id = id-get(lex.start, r2.pos - r1.pos - 1)
            .last-token = t
            psr.parse(t, tok)
         }
         case #struct-space-id {
            r1'rdr. = ?
            r1.ref = lex.start
            r1.pos += 6
            loop {
               if (&&, r1.p1[0] != '' , r1.p1[0] != ''\n, r1.p1[0] != ''\t) { break }
               r1.pos++
            }
            r2'rdr. = ?
            r2.ref = lex.cursor
            id' = id-get(r1.ref, r2.pos - r1.pos)
            tok.ptr.ptr = tag-type-get(id, #struct)
            .last-token = t
            psr.parse(t, tok)
         }
         case #union-space-id {
            r1'rdr. = ?
            r1.ref = lex.start
            r1.pos += 5
            loop {
               if (&&, r1.p1[0] != '' , r1.p1[0] != ''\n, r1.p1[0] != ''\t) { break }
               r1.pos++
            }
            r2'rdr. = ?
            r2.ref = lex.cursor
            id' = id-get(r1.ref, r2.pos - r1.pos)
            tok.ptr.ptr = tag-type-get(id, #union)
            .last-token = t
            psr.parse(t, tok)
         }
         case #enum-space-id {
            r1'rdr. = ?
            r1.ref = lex.start
            r1.pos += 4
            loop {
               if (&&, r1.p1[0] != '' , r1.p1[0] != ''\n, r1.p1[0] != ''\t) { break }
               r1.pos++
            }
            r2'rdr. = ?
            r2.ref = lex.cursor
            id' = id-get(r1.ref, r2.pos - r1.pos)
            tok.ptr.ptr = tag-type-get(id, #enum)
            .last-token = t
            psr.parse(t, tok)
         }
         case #id {
            r1'rdr. = ?
            r1.ref = lex.start
            r2'rdr. = ?
            r2.ref = lex.cursor
            id' = id-get(lex.start, r2.pos - r1.pos)
            loop i' = 0; .typename-c; i++ {
               if .typename-id-v[i] == id {
                  tok.ptr.ptr = .typename-type-v[i]
                  tok.ptr.ptr2 = null // Not an extern
                  t = #type
                  "goto id_is_a_type;"
               }
            }
            tok.id.id = id
            "id_is_a_type:;"
            .last-token = t
            psr.parse(t, tok)
         }
         case #i32 {
            str' = lex.start
            num'u32 = 0
            base'u32 = 10
            start' = 0
            if (&&, str[0] == ''0, (||, str[1] == ''x, str[1] == ''X)) {
               base = 16
               start = 2
            }
            loop i' = start; ; i++ {
               c' = str[i]
               digit'u32 = 16
               if (&&, c >= ''0, c <= ''9) {
                  digit = c - ''0
               } elif (&&, c >= ''a, c <= ''f) {
                  digit = (c - ''a) + 10
               } elif (&&, c >= ''A, c <= ''F) {
                  digit = (c - ''A) + 10
               }
               if digit >= base { break }
               num = (num * base) + digit
            }
            tok.i32.id = num
            .last-token = t
            psr.parse(t, tok)
         }
         case #f32-num {
            tok.f32.f32 = parse-f32(lex.start)
            .last-token = t
            psr.parse(t, tok)
         }
         case #f64-num {
            tok.f64.f64 = parse-f64(lex.start)
            .last-token = t
            psr.parse(t, tok)
         }
         case #string {
            tok.ptr.ptr = lex.start
            tok.ptr.ptr2 = lex.cursor
            .last-token = t
            psr.parse(t, tok)
         }
         case #c-code {
            tok.ptr.ptr = lex.start
            tok.ptr.ptr2 = lex.cursor
            .last-token = t
            psr.parse(t, tok)
         }
         default {
            .last-token = t
            psr.parse(t, tok)
         }
      }
      if t == #end { break }
      pos' = lex.start
      loop pos < lex.cursor {
         if (pos[0] & 128) == 0 {
            if pos[0] == ''\n {
               next-row++
               next-col = 1
            } else {
               next-col++
            }
         }
         pos++
      }
   }
   .last-token = #nil
   psr.parse(#nil, tok)
   psr.free()
}
id-c'id
id-get(ptr'char @const[], lensz'usz)'id {
   if lensz > 255 {
      'c1.stdout{"Id is too long: " ptr, lensz "\n"}
      stack-trace-exit()
   }
   len'u8 = lensz
   crc32c' = crc32c(0, ptr, len)
   loop i'id = 0; .id-c; i++ {
      if (&&, i[]crc32c == crc32c, i[]len == len, 'c.memcmp(i[]ptr, ptr, len) == 0) {
         return i
      }
   }
   id' = .id-c++
   id[]crc32c = crc32c
   id[]len = len
   id[]ptr = ptr
   return id
}
