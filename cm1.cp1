      }
      if i == end {
         'c1.stdout{li ": Incomplete escape sequence in string literal\n"}
         'c.exit(#failure)
      }
      escaped'u8 = 'u8(raw[i++])
      if escaped == ''a {
         cm1-string-put(pos, 7, li)
      } elif escaped == ''b {
         cm1-string-put(pos, 8, li)
      } elif escaped == ''f {
         cm1-string-put(pos, 12, li)
      } elif escaped == ''n {
         cm1-string-put(pos, 10, li)
      } elif escaped == ''r {
         cm1-string-put(pos, 13, li)
      } elif escaped == ''t {
         cm1-string-put(pos, 9, li)
      } elif escaped == ''v {
         cm1-string-put(pos, 11, li)
      } elif (||, escaped == 34, escaped == 39, escaped == 63, escaped == 92) {
         cm1-string-put(pos, escaped, li)
      } elif (&&, escaped >= ''0, escaped <= ''7) {
         value'u32 = escaped - ''0
         digit-c' = 1
         loop (&&, digit-c < 3, i < end) {
            digit'u8 = 'u8(raw[i])
            if (||, digit < ''0, digit > ''7) { break }
            value = (value * 8) + (digit - ''0)
            digit-c++
