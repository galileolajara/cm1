cfg-func-list'id
output-type-name(f'c1'sprintf, type'type) {
   if type.kind == #struct {
      f.add{"struct " type.name}
   } elif type.kind == #union {
      f.add{"union " type.name}
   } elif type.kind == #enum {
      f.add{"enum " type.name}
   } else {
      f.add{type.name}
   }
}
output-array-dims(f'c1'sprintf, array-dim-start'u32, array-dim-c'u32) {
   loop i' = 0; array-dim-c; i++ {
      f.add{"[" .array-dim-v[array-dim-start + i] "]"}
   }
}
output-fields(f'c1'sprintf, type'type) {
   field-v' = type.field-v
   loop j' = 0; type.field-c; j++ {
      field' = field-v[j]
      type2' = field.type-src
      f.add{"   "}
      output-type-name(f, type2)
      f.add{field.stars-src ''  field.name}
      output-array-dims(f, field.array-dim-start, field.array-dim-c)
      f.add{";\n"}
   }
}
output-enum-members(f'c1'sprintf, type'type) {
   start' = type.enum-member-start
   loop i' = 0; type.field-c; i++ {
      member' = .enum-member-v[start + i]
      f.add{"   " member.name " = " member.value}
      if (i + 1) != type.field-c {
         f.add{","}
      }
      f.add{"\n"}
   }
}
clear-memory-lexer()
clear-memory-parser()
clear-memory() {
   clear-memory-lexer()
   clear-memory-parser()
   // Clear only the prefixes used by the previous compilation. Some entries
   // contain pointers or flags which are not overwritten on every allocation.
   id-c' = 'u32(.id-c)
   'c.memset(.id-soa.crc32c, 0, id-c * 'u32['usz])
   'c.memset(.id-soa.ptr, 0, id-c * 'ref['usz])
   'c.memset(.id-soa.len, 0, id-c * 'u8['usz])

   'c.memset(.cm1-data-mem, 0, .cm1-data-pos)
   'c.memset(.decl-type-v, 0, .decl-c * 'decl-type['usz])
   'c.memset(.decl-ptr-v, 0, .decl-c * 'ref['usz])
   'c.memset(.type-v, 0, .type-c * 'type['usz])
   'c.memset(.typename-id-v, 0, .typename-c * 'id['usz])
   'c.memset(.typename-type-v, 0, .typename-c * 'ref['usz])
   'c.memset(.gvar-v, 0, .gvar-c * 'gvar['usz])
   'c.memset(.gvar-name-v, 0, .gvar-c * 'id['usz])
   'c.memset(.array-dim-v, 0, .array-dim-count * 'u32['usz])
   'c.memset(.field-v, 0, .field-c * 'field['usz])
   // field-mem-c is stored as a byte count.
   'c.memset(.field-mem-v, 0, .field-mem-c)
   'c.memset(.enum-member-v, 0, .enum-member-c * 'enum-member['usz])

   'c.memset(.func-v, 0, .func-c * 'func['usz])
   'c.memset(.func-name-v, 0, .func-c * 'id['usz])
   'c.memset(.func-decl-arg-v, 0, .func-decl-arg-c * 'func-decl-arg['usz])

   'c.memset(.expr-str-v, 0, .expr-str-c * 'expr-string['usz])
   loop i' = 0; .expr-call-stack-depth; i++ {
      'c.memset(.expr-call-stack-v[i], 0, .expr-call-stack-c[i] * 'ref['usz])
   }
   'c.memset(.expr-call-stack-c, 0, .expr-call-stack-depth * 'u8['usz])

   'c.memset(.space-v, 0, .space-c * 'space['usz])
   'c.memset(.space-stack-v, 0, .space-stack-c * 'ref['usz])
   'c.memset(.lvar-v, 0, .lvar-c * 'lvar['usz])
   'c.memset(.lvar-name-id-v, 0, .lvar-name-c * 'id['usz])
   'c.memset(.lvar-name-idx-v, 0, .lvar-name-c * 'u16['usz])
   'c.memset(.lvar-name-space-v, 0, .lvar-name-c * 'u16['usz])
   'c.memset(.if-stack-v, 0, .if-stack-c * 'ref['usz])
   'c.memset(.named-label-v, 0, .named-label-c * 'named-label-entry['usz])
   'c.memset(.goto-jump-v, 0, .goto-jump-c * 'goto-jump-entry['usz])
   'c.memset(.control-stack-v, 0, .control-stack-c * 'control-frame['usz])
   'c.memset(.break-jump-v, 0, .break-jump-c * 'ref['usz])
   'c.memset(.continue-jump-v, 0, .continue-jump-c * 'ref['usz])
   'c.memset(.switch-stack-v, 0, .switch-stack-c * 'ref['usz])

   bytecode-start'rdr. = ?
   bytecode-start.ref = .cm1-bytecode.buf
   if .cm1-bytecode-wtr.pos > bytecode-start.pos {
      'c.memset(
         .cm1-bytecode.buf,
         0,
         .cm1-bytecode-wtr.pos - bytecode-start.pos
      )
   }
   offset-byte-c' = (.func-bc-idx + 1) * 'u32['usz]
   offset-start'rdr. = ?
   offset-start.ref = .cm1-bytecode.buf
   offset-start.pos -= offset-byte-c
   'c.memset(offset-start.ref, 0, offset-byte-c)
   'c.memset(.cm1-bytecode.str, 0, .cm1-string-pos)
   'c.memset(.cm1-string-offset-v, 0, .cm1-string-count * 'u32['usz])
   'c.memset(.cm1-string-len-v, 0, .cm1-string-count * 'u32['usz])
   'c.memset(.cm1-string-crc32c-v, 0, .cm1-string-count * 'u32['usz])

   .printed-error = false
   .cfg-has-cm1 = false
   .cfg-func-list = #nil
   .id-printf = #nil
   .id-c = 'id(0)
   .cm1-data-pos = 0
   .decl-c = 0
   .type-c = 0
   .typename-c = 0
   .gvar-c = 0
   .array-dim-count = 0
   .field-c = 0
   .field-mem-c = 0
   .field-offset = 0
   .field-max-size = 0
   .field-max-align = 0
   .enum-member-c = 0
   .enum-member-start = 0
   .enum-next-value = 0
   .func-c = 0
   .func-decl-arg-c = 0
   .func-c-idx = 0
   .func-bc-idx = 0
   .func-arg-start = 0
   .func-arg-c = 0
   .func-lvar-stack-c = 0
   .func = null
   .func-type = null
   .func-name = #nil
   .func-is-bytecode = false
   .declarator-type = null
   .declarator-extern = false
   .current-type = null
   .current-stars = #0
   .expr-str-c = 0
   .expr-discard-bytecode-depth = 0
   .expr-call-stack-depth = 0
   .space-c = 0
   .space-stack-c = 0
   .lvar-c = 0
   .lvar-name-c = 0
   .if-stack-c = 0
   .named-label-c = 0
   .goto-jump-c = 0
   .control-stack-c = 0
   .break-jump-c = 0
   .continue-jump-c = 0
   .switch-stack-c = 0
   .cm1-bytecode-wtr.ref = null
   .cm1-string-pos = 0
   .cm1-string-count = 0
}
