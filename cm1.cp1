         }
         if value > 255 {
            'c1.stdout{li ": Octal escape is too large for a byte\n"}
            'c.exit(#failure)
         }
         cm1-string-put(pos, value, li)
      } elif escaped == ''x {
         if i == end {
            'c1.stdout{li ": Hexadecimal escape requires at least one digit\n"}
            'c.exit(#failure)
         }
         value'u32 = 0
