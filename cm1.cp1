   return type-storage-size(final-type, final-stars, li)
}
type-storage-align(type'type, stars'stars, li'line-info)'u32 {
   if stars != #0 {
      return 'usz['usz]
   }
   switch type.kind {
      case #i8 { return 1 }
      case #u8 { return 1 }
      case #i16 { return 2 }
      case #u16 { return 2 }
      case #i32 { return 4 }
      case #u32 { return 4 }
      case #f32 { return 4 }
      case #i64 { return 8 }
      case #u64 { return 8 }
      case #f64 { return 8 }
      case #enum { return 4 }
   }
   if type.is-aggregate() {
      if type.field-v == null {
         'c1.stdout{li ": Struct or union type is incomplete\n"}
         'c.exit(#failure)
      }
