      'c.exit(#failure)
   }
   out-start = .array-dim-count
   out-size = type-storage-size(type, stars, li)
   loop i' = 0; array-dim-c; i++ {
      dim' = array-dims[i]
      .array-dim-v[.array-dim-count++] = dim
      if dim > (0xffffffff / out-size) {
