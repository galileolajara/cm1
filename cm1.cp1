cm1-string-intern(raw'char @const[], raw-len'u32, li'line-info, out-len'u32&)'u32 {
   if (||, raw-len < 2, raw[0] != 'char(34), raw[raw-len - 1] != 'char(34)) {
      'c1.stdout{li ": Invalid string literal\n"}
      'c.exit(#failure)
   }
   start' = .cm1-string-pos
   pos' = start
   end' = raw-len - 1
   loop i' = 1; i < end; {
      c'u8 = 'u8(raw[i++])
      if c != 92 {
         cm1-string-put(pos, c, li)
