union 'rdr[
   ref'ref,
   pos'usz,
   p1'u8[],
   p2'u16[],
   char'char[],
   p4'u32[],
   p8'u64[],
   f4'f32[],
   f8'f64[],
   op'op[],
   ] {
   n1(r'this)'u8 @inline {
